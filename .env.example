# ── OpenAI (opcional) ─────────────────────────────────────────────────────────
# Necessário para funcionalidades que usam LLM (Etapa 6).
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4.1

# Ativar extração LLM híbrida no pipeline de arquivos.
# Quando vazio ou ausente, o pipeline usa apenas o mapper determinístico.
USE_LLM_EXTRACTION=true

# ── Supabase (opcional) ───────────────────────────────────────────────────────
# Quando definidas, o backend de sessões usa Supabase automaticamente.
# Sem essas variáveis, o sistema usa armazenamento em filesystem (padrão local).
#
# Obtenha em: https://supabase.com/dashboard → seu projeto → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-service-role-key

# Bucket privado usado para salvar DOCX gerados.
GENERATED_MEMORIALS_BUCKET=generated-memorials

# Tempo de expiração das URLs assinadas de download, em segundos.
GENERATED_MEMORIALS_SIGNED_URL_TTL=3600

# Origens permitidas para o frontend local.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Sessões filesystem (opcional) ─────────────────────────────────────────────
# Diretório onde as sessões são salvas quando o backend é filesystem.
# Padrão: "sessions" (relativo à raiz do projeto)
SESSIONS_DIR=sessions
