# ── Ambiente da aplicação ─────────────────────────────────────────────────────
# local: desenvolvimento na máquina
# test: testes automatizados
# production: deploy no Railway
APP_ENV=local

# ── OpenAI (opcional) ─────────────────────────────────────────────────────────
# Necessário para funcionalidades que usam LLM (Etapa 6).
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4

# Ativar extração LLM híbrida no pipeline de arquivos.
# Quando vazio ou ausente, o pipeline usa apenas o mapper determinístico.
USE_LLM_EXTRACTION=true

# ── Supabase (opcional) ───────────────────────────────────────────────────────
# Quando definidas, o backend de sessões usa Supabase automaticamente.
# Sem essas variáveis, o sistema usa armazenamento em filesystem (padrão local).
#
# Para memoriais persistidos (`/from-files/persist`), produção exige
# `SUPABASE_URL`, `SUPABASE_KEY` e `GENERATED_MEMORIALS_BUCKET` explícitos.
#
# Obtenha em: https://supabase.com/dashboard → seu projeto → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-service-role-key

# Bucket privado usado para salvar DOCX gerados.
# Em production, configure explicitamente um bucket persistente.
GENERATED_MEMORIALS_BUCKET=generated-memorials

# Tempo de expiração das URLs assinadas de download, em segundos.
GENERATED_MEMORIALS_SIGNED_URL_TTL=3600

# Origens permitidas para CORS, separadas por vírgula.
# Em local/test, pode ficar vazio para usar defaults locais seguros.
# Em production, configure explicitamente a URL pública do dashboard.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Sessões filesystem (opcional) ─────────────────────────────────────────────
# Diretório onde as sessões são salvas quando o backend é filesystem.
# Padrão: "sessions" (relativo à raiz do projeto)
SESSIONS_DIR=sessions

# ── Limites de upload ─────────────────────────────────────────────────────────
# Bloqueiam silenciosamente projetos grandes na ingestão antes de chegar no
# pipeline. Cada limite produz um código de erro distinto que o frontend pode
# tratar especificamente (upload_too_many_files, upload_file_too_large,
# upload_total_too_large, upload_too_many_pages).
MAX_FILE_COUNT=10
MAX_FILE_SIZE_MB=50
MAX_TOTAL_UPLOAD_MB=200
MAX_PDF_PAGES=100

# GLP v2 (contrato estruturado). As rotas /api/v1/memoriais/glp/v2/* ficam
# disponíveis naturalmente quando templates/glp/v2/template.docx existir; sem o
# arquivo a API retorna 503 (glp_v2_template_pending).

# ── Resiliência OpenAI ────────────────────────────────────────────────────────
# Timeout (segundos) para cada chamada ao OpenAI Responses API.
OPENAI_REQUEST_TIMEOUT=180
